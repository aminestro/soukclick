    "zod":                    "^3.23.8",
    "react-hook-form":        "^7.54.2",
    "@hookform/resolvers":    "^3.9.1",

    "@aws-sdk/client-s3":     "^3.723.0",

    "resend":                 "^4.0.1",

    "sonner":                 "^1.7.1",

    "clsx":                   "^2.1.1",
