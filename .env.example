# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (EasyPanel internal network or external)
DATABASE_URL="postgresql://soukclick:changeme@localhost:5432/soukclick"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32-char-random-string"
NEXTAUTH_URL="https://soukclick.store"

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Found in: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# Format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
R2_BUCKET_NAME="soukclick-media"
# Your R2 custom domain (public bucket)
R2_PUBLIC_URL="https://media.soukclick.store"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="SoukClick <noreply@soukclick.store>"

# ─── Meta (Facebook) Tracking ─────────────────────────────────────────────────
# Events Manager → Data Sources → your Pixel
META_PIXEL_ID="your-meta-pixel-id"
# System user access token with ads_management + pixel scope
META_ACCESS_TOKEN="your-meta-access-token"
# Only needed during CAPI testing in Meta Events Manager
META_TEST_EVENT_CODE="TEST12345"

# ─── TikTok Tracking ──────────────────────────────────────────────────────────
TIKTOK_PIXEL_ID="your-tiktok-pixel-id"
TIKTOK_ACCESS_TOKEN="your-tiktok-access-token"

# ─── Google Analytics / GTM ───────────────────────────────────────────────────
# GA4 Measurement ID (format: G-XXXXXXXXXX)
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
# Google Tag Manager container ID (format: GTM-XXXXXXX)
GTM_ID="GTM-XXXXXXX"

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# Admin phone to receive order alerts (international format)
WHATSAPP_ADMIN_PHONE="+212600000000"

# ─── App (Public — exposed to browser) ───────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://soukclick.store"
NEXT_PUBLIC_META_PIXEL_ID="your-meta-pixel-id"
NEXT_PUBLIC_TIKTOK_PIXEL_ID="your-tiktok-pixel-id"
NEXT_PUBLIC_GA4_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# ─── App (Internal) ───────────────────────────────────────────────────────────
NODE_ENV="production"
PORT="3000"

# ─── Rate Limiting (in-memory — no Redis in V1) ───────────────────────────────
# Max order submissions per IP per window
RATE_LIMIT_MAX="10"
RATE_LIMIT_WINDOW_MS="60000"
